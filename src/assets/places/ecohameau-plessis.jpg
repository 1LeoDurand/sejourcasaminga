<meta name="generator" content="Elementor 3.35.6; features: e_font_icon_svg, additional_custom_breakpoints; settings: css_print_method-external, google_font-enabled, font_display-swap">
<style type="text/css">

/* Remove margin bottom for last P */

	* p:last-child {margin-bottom: 0px !important;}


/* PADDING */

.pt-sm {padding-top: 12px;}
.pr-sm {padding-right: 12px;}
.pb-sm {padding-bottom: 12px;}
.pl-sm {padding-left: 12px;}

.pt-md {padding-top: 24px;}
.pr-md {padding-right: 24px;}
.pb-md {padding-bottom: 24px;}
.pl-md {padding-left: 24px;}

.pt-lg {padding-top: 48px;}
.pb-lg {padding-bottom: 48px;}

.pt-xl {padding-top: 96px;}
.pb-xl {padding-bottom: 96px;}

@media (min-width: 768px) {
.pl-half-column {padding-left: 4.16%;}
.pr-half-column {padding-right: 4.16%;}
}

	
/* BUTTONS */
	
/* Hover */
.elementor-button:hover{
     filter: brightness(95%);}
	
/* Dark button*/
.button-dark .elementor-button{
    background-color: #2D164C;}
		
/* Violet Button */
.button-violet .elementor-button{
    background-color: #825184;}
	
/* Outline button */
.button-outline .elementor-button{
    background-color: transparent;
		color: #ffffff !important;
    border: solid 1px #ffffff;}
.button-outline .elementor-button:hover{
    background-color: #ffffff;
		color: #2D164C !important;}
	
/* Outline dark button */
.button-outline-dark .elementor-button{
    background-color: transparent;
		color: #2D164C;
    border: solid 1px #2D164C;}
.button-outline-dark .elementor-button:hover{
    background-color: #2D164C;
		color: #ffffff;}
	
/* Simple text button */
.button-simple-text .elementor-button{
    background-color: transparent;
		padding: 0px;}
	
/* Underline button */
.button-underline .elementor-button{
    background-color: transparent;
		text-decoration: underline;
		padding: 0px;}
	
/* Underline dark button */
.button-underline-dark .elementor-button{
    background-color: transparent;
		text-decoration: underline;
		color: #2D164C;
		padding: 0px;}
.button-underline-dark .elementor-button:hover{
    background-color: transparent !important;
		color: #2D164C !important;
}
	
	

/* BORDER RADIUS */

.br-img img {
    border-radius: 8px !important;
}
	
.br-img-top img {
    border-top-left-radius: 8px !important;
    border-top-right-radius: 8px !important;
}
	
.br-img-bottom img {
    border-bottom-left-radius: 8px !important;
    border-bottom-right-radius: 8px !important;
}

.br-container {
    border-radius: 8px !important;
    overflow: hidden !important;
}

	
.br-container-top {
    border-top-left-radius: 8px !important;
	  border-top-right-radius: 8px !important;
    overflow: hidden !important;
}
	
	
.br-container-bottom {
    border-bottom-left-radius: 8px !important;
	  border-bottom-right-radius: 8px !important;
    overflow: hidden !important;
}
	

/* VERTICAL DOTS */
	

	@media (min-width: 1025px) {
	.vertical-dots-timeline:after {
    content:"";
    position: absolute;
    top: 85px;
    bottom: 0;
    left: 50%;
    border-left: 2px dotted #AF78B1;
	}
	.vertical-dots-timeline-full-height:after {
    top: 0;
	}
}

@media (min-width: 1025px) {

.vertical-dots:after {
    content:"";
    display: block;
    width: 0px;
    border-right: dotted 2px #FFFFFF;
    height: 94%;
    position: absolute;
    top: 3%;
    left: calc(50% - 1px);
}

.vertical-dots-violet:after {
    border-color: #AF78B1;
}

.vertical-dots-orange:after {
    border-color: #D6AE54;
}
	
.vertical-dots-light:after {
    border-color: #F2E5CA;
}
	
}


/* BACKGROUND WITH STARS */
	
.background-stars {
		background-image: url(https://amma.org/wp-content/uploads/bg-stars-violet.png);
    background-position: top center;
    background-repeat: no-repeat;
		background-size: auto 250px !important;
}
	
/* BLOCKQUOTES */
	
@media (min-width:1164px) {
		.quote-left .elementor-blockquote:before {
    position: absolute;
    left: 0px;
    top: 0;
	}
	.quote-left .elementor-widget-container{
		padding: 0 100px;
	}
}
	.li-space-sm li {
		margin:4px 0;
	}
	.li-space-md li {
		margin:10px 0;
	}
	
/* FIX BUG - CENTER COUNTER TITLES i.e. WORLDWIDE IMPACT */
.elementor-counter-title {
	text-align: center;
}
	
/* AMELIA OVERRIDES */
.amelia-v2-booking {
	--el-color-primary: rgba(45, 22, 77, 1)!important;
}
.amelia-v2-booking #amelia-container .am-ec:not(.am-no-border) {
	box-shadow: rgb(209, 213, 215) 0px 2px 2px -1px, rgba(209, 213, 215, 0.3) 0px 0px 11px, rgba(45, 22, 77, 1) 8px 0px 0px inset!important;
}
.amelia-v2-booking #amelia-container .am-ecs__side-card, 
.amelia-v2-booking #amelia-container .am-ecs .am-evt-wrapper {
	--am-c-evt: rgba(45, 22, 77, 1)!important;
}
</style>
<style type="text/css">
	
body.no-featured-image .hide-if-no-featured-image {
  display: none !important;
}

	
.tooltip {
  position: relative;
  display: inline-block;
  border-bottom: 1px dotted black;
}

.tooltip .tooltiptext {
  visibility: hidden;
  width: 120px;
  background-color: black;
  color: #fff;
  text-align: center;
  border-radius: 6px;
  padding: 5px 0;
  position: absolute;
  z-index: 1;
  bottom: 150%;
  left: 50%;
  margin-left: -60px;
}

.tooltip .tooltiptext::after {
  content: "";
  position: absolute;
  top: 100%;
  left: 50%;
  margin-left: -5px;
  border-width: 5px;
  border-style: solid;
  border-color: black transparent transparent transparent;
}

.tooltip:hover .tooltiptext {
  visibility: visible;
}
	
.hidden-by-default {
    max-height: 0;
}

		/* Initially hide the TOP banner */
#top-banner {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.75s ease-in-out;  /* transition effect */
}

/* Style when the redirect banner is visible */
#top-banner:not(.hidden-by-default) {
  max-height: 100px;  /* Set this to the maximum height your banner needs */
}

	/* Initially hide the redirect banner */
#banner {
  max-height: 0;
  overflow: hidden;
  transition: max-height 1.5s ease-in-out;  /* transition effect */
}

/* Style when the redirect banner is visible */
#banner:not(.hidden) {
  max-height: 700px;  /* Set this to the maximum height your banner needs */
}

	
/* ********************************************************************* */
.home-explore-link > .elementor-widget-container {
	display:inline-block !important;
	border-bottom: solid 1px #2D164C;
}
	.group-list {
		
	}

	.page-header h1.entry-title {
    display: none !important;
}
	
figure.wp-block-image {
		margin:40px 0;
	}
.wp-block-image figcaption {
			text-align:left;
			font-family: "Lora", serif;
			font-style: italic;
			font-weight:400;
			font-size: 18px;
			color:#825184;
			margin:0;
			padding: 16px 20px 20px 20px;
			background-color: #E5E4EB;
}
	
	@media only screen and (max-width: 1179px) {
		.hide-bkg {
					background-image: none !important;
		}		
	}
	
@media only screen and (min-width: 1180px) {
	
	figure.news-image-caption-left::before, figure.news-image-caption-right::before {
				content: "";
				position: absolute;
				top: 0;
				left: 50%;
				width: 100vw;
				height: 100%;
				background-color: #E5E4EB; 
				z-index: -1;
				transform: translateX(-50%);
	}

	figure.news-image-caption-right, figure.news-image-caption-left{
		position: relative;
		display:flex;
	/* 	flex-direction: row; */
		justify-content: space-between;
		flex-wrap: wrap;
/* 		align-items: flex-start; */
		width:1104px;
		margin-left: calc((704px - 1104px) / 2);
		padding: 30px 0;
	}
	.news-image-caption-right img, .news-image-caption-left img {
		width:704px;
	}
	.news-image-caption-right figcaption, .news-image-caption-left figcaption {
		text-align:left;
		width:350px;
		padding: 0;
		font-family: "Lora", serif;
		font-style: italic;
		font-weight:400;
		font-size: 22px;
		color:#825184;
		margin:0;
	}
	figure.news-image-caption-left {
		flex-direction: row-reverse;
	}
}


@media only screen and (max-width: 450px) {
	
	.hide-me-mobile {
				display: none !important;
	}

/* For phone make gallery lightbox image the width of the screen: */
	.elementor-lightbox .elementor-lightbox-item {
		padding:0 !important;
	}
	
/* For phone make image and caption box the width of the screen: */
	
	figure.wp-block-image {
		width:100vw;
		padding: 0;
		margin:0 0 30px -24px;
	}
	.wp-block-image figcaption {
		text-align:left;
		font-family: "Lora", serif;
		font-style: italic;
		font-weight:400;
		font-size: 18px;
		color:#825184;
		padding: 16px 20px 20px 20px;
		background-color: #E5E4EB;
	}
}
